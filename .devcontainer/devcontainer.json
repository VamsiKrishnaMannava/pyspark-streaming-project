{
  "name": "Spark DevContainer",
  "dockerAttach": {
    "containerName": "spark-container"
  },
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3"
      },
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "VisualStudioExptTeam.vscodeintellicode"
      ]
    }
  },
  "forwardPorts": [7077, 8080],
  "postAttachCommand": "echo 'Attached to Spark container: spark-container'"
}
